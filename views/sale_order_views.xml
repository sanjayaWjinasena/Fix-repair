<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Allow "Order Payment Type" (x_studio_order_payment_method) to be
        edited while the SO is in Quotation (draft) or Quotation Sent state.

        The Studio-generated readonly condition locks this field whenever
        x_studio_customer_payment_method == 'Cash', which prevents repair
        quotations from having a payment type set at all.  This view runs
        after Studio (priority 100 > Studio 99) and replaces that condition
        with a simple state-based rule: editable until the order is confirmed.
    -->
    <record id="sale_order_form_repair_payment_method" model="ir.ui.view">
        <field name="name">sale.order.form.repair.payment.method</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='x_studio_order_payment_method']" position="attributes">
                <attribute name="readonly">state in ('cancel', 'done', 'sale')</attribute>
            </xpath>
        </field>
    </record>

</odoo>
