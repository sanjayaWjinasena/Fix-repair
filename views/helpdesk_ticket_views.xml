<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="helpdesk_ticket_form_assign_to_me" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.assign.to.me</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <!-- Visible in New stage only -->
                <button name="action_send_to_factory"
                        type="object"
                        string="Send to Factory"
                        class="btn-primary"
                        invisible="stage_id.name != 'New'"/>

                <!-- Visible in Sent to Factory stage only -->
                <button name="action_received_at_factory"
                        type="object"
                        string="Received at Factory"
                        class="btn-primary"
                        invisible="stage_id.name != 'Sent to Factory'"/>

                <!-- Visible in Repair Completed stage only -->
                <button name="action_send_to_sales_centre"
                        type="object"
                        string="Send to Sales Centre"
                        class="btn-primary"
                        invisible="stage_id.name != 'Repair Completed'"/>

                <!-- Visible in Sent to Sales Centre stage only -->
                <button name="action_received_at_sales_centre"
                        type="object"
                        string="Received at Sales Centre"
                        class="btn-primary"
                        invisible="stage_id.name != 'Sent to Sales Centre'"/>

                <!-- Always visible unless already assigned to current user -->
                <button name="action_assign_to_me"
                        type="object"
                        string="Assign to Me"
                        class="btn-secondary"
                        invisible="user_id == uid"/>

            </xpath>
        </field>
    </record>

</odoo>
