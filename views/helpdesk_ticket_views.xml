<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="helpdesk_ticket_form_assign_to_me" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.assign.to.me</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <!-- Stored computed field — web_read reads a plain DB varchar, no many2one traversal -->
            <xpath expr="//field[@name='name']" position="before">
                <field name="repair_stage_state" invisible="1"/>
            </xpath>

            <xpath expr="//header" position="inside">

                <button name="action_send_to_factory"
                        type="object"
                        string="Send to Factory"
                        class="btn-primary"
                        invisible="repair_stage_state != 'new'"/>

                <button name="action_received_at_factory"
                        type="object"
                        string="Received at Factory"
                        class="btn-primary"
                        invisible="repair_stage_state != 'sent_to_factory'"/>

                <button name="action_send_to_sales_centre"
                        type="object"
                        string="Send to Sales Centre"
                        class="btn-primary"
                        invisible="repair_stage_state != 'repair_completed'"/>

                <button name="action_received_at_sales_centre"
                        type="object"
                        string="Received at Sales Centre"
                        class="btn-primary"
                        invisible="repair_stage_state != 'sent_to_sales_centre'"/>

                <button name="action_assign_to_me"
                        type="object"
                        string="Assign to Me"
                        class="btn-secondary"
                        invisible="user_id == uid"/>

            </xpath>
        </field>
    </record>

</odoo>
